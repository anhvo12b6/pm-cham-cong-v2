# 1. Cấu hình Cổng chạy ứng dụng Web Backend
PORT=3000

# 2. Chuỗi bí mật để mã hóa mã Token JWT (Bạn có thể gõ bừa một chuỗi dài ký tự)
JWT_SECRET=MitacoWebConfigKeySecure2026_@!#

# 3. Tài khoản kết nối SQL Server (Dùng chung cho cả 2 Database vì chúng nằm trên cùng 1 server)
DB_SERVER=175.100.107.170      # Chỉ điền phần IP trước dấu phẩy
DB_PORT=54330            # Nếu DB nằm ở máy khác, hãy điền IP ví dụ: 192.168.1.15
DB_USER=sa                     # Tài khoản đăng nhập SQL Server
DB_PASSWORD=Thaco@123   # Mật khẩu của tài khoản sa

# 4. Khóa bí mật SSO (appapikey) từ IT cung cấp cho Workspace
JWT_KEY=CHẤM CÔNG APP V2